# Copy this file to .env.local and fill in your real values.
# .env.local is already in .gitignore, so your real keys never get committed.

# Found in your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Found at developer.transportapi.com after registering an app
VITE_TRANSPORTAPI_APP_ID=your-app-id
VITE_TRANSPORTAPI_APP_KEY=your-app-key
